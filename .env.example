# SkinTwin-ASI Shopify App — Environment Variables
# Copy this file to .env.local and fill in the values.

# Shopify API credentials (from your Shopify Partner dashboard)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Shopify OAuth scopes (space-separated list)
SCOPES=read_products,write_products,read_customers,write_customers,read_orders,read_product_listings

# The public URL of this app (required for OAuth redirect and App Bridge)
# Example: https://your-app.vercel.app
HOST=https://your-app.vercel.app

# Session storage: "memory" | "custom"
SESSION_STORAGE=memory

# Node environment
NODE_ENV=development
